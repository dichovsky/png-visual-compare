{
    "name": "png-visual-compare",
    "version": "6.0.0",
    "description": "Node.js utility to compare PNG files or their areas",
    "keywords": [
        "visual testing",
        "compare png",
        "compare images",
        "png",
        "png compare",
        "png diff",
        "image diff",
        "diff"
    ],
    "homepage": "https://github.com/dichovsky/png-visual-compare#readme",
    "bugs": {
        "url": "https://github.com/dichovsky/png-visual-compare/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dichovsky/png-visual-compare.git"
    },
    "funding": {
        "type": "buymeacoffee",
        "url": "https://buymeacoffee.com/dichovsky"
    },
    "license": "MIT",
    "author": "Igor Magdich <magdich.igor@gmail.com>",
    "sideEffects": [
        "./out/vitest.mjs",
        "./out/jest.js"
    ],
    "exports": {
        ".": {
            "types": "./out/index.d.ts",
            "default": "./out/index.js"
        },
        "./vitest": {
            "types": "./out/vitest.types.d.ts",
            "import": "./out/vitest.mjs",
            "default": "./out/vitest.mjs"
        },
        "./jest": {
            "types": "./out/jest.d.ts",
            "default": "./out/jest.js"
        }
    },
    "main": "./out/index.js",
    "types": "./out/index.d.ts",
    "files": [
        "./out"
    ],
    "scripts": {
        "prebuild": "npm run clean",
        "build": "tsc --pretty --project tsconfig.prod.json",
        "clean": "rimraf ./out ./coverage ./test-results",
        "codemap": "node ./scripts/generate-codemap.mjs",
        "postcodemap": "npm run format",
        "docker:build": "docker build --compress -t test-png-visual-compare .",
        "docker:run": "docker run --rm test-png-visual-compare",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepublishOnly": "npm test && npm run build",
        "test": "npm run test:unit && npm run test:e2e",
        "test:docker": "npm run clean && npm run docker:build && npm run docker:run",
        "pretest:e2e": "npx playwright install chromium",
        "test:e2e": "playwright test",
        "test:license": "node ./scripts/check-licenses.mjs",
        "pretest:unit": "npm run clean && npm run lint && npm run format:check && npm run test:license && npm run typecheck",
        "test:unit": "VITEST_FULL_COVERAGE=true vitest run --coverage",
        "tool:excluded-areas-builder": "node -e \"const { execFileSync } = require('node:child_process'); if (process.platform === 'darwin') { execFileSync('open', ['tools/excluded-areas-builder.html'], { stdio: 'inherit' }); } else if (process.platform === 'linux') { execFileSync('xdg-open', ['tools/excluded-areas-builder.html'], { stdio: 'inherit' }); } else { throw new Error('Unsupported platform: development tooling is only supported on macOS and Linux'); }\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "pixelmatch": "~7.2.0",
        "pngjs": "~7.0.0"
    },
    "devDependencies": {
        "@playwright/test": "~1.59.1",
        "@types/node": "~25.6.0",
        "@types/pngjs": "~6.0.5",
        "@vitest/coverage-v8": "~4.1.5",
        "eslint": "~10.2.1",
        "prettier": "~3.8.3",
        "rimraf": "~6.1.3",
        "typescript": "~6.0.3",
        "typescript-eslint": "~8.59.1",
        "vitest": "~4.1.5"
    },
    "peerDependencies": {
        "jest": ">=29 <31",
        "vitest": ">=4.1.0 <5"
    },
    "peerDependenciesMeta": {
        "jest": {
            "optional": true
        },
        "vitest": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=20"
    },
    "os": [
        "darwin",
        "linux"
    ]
}
