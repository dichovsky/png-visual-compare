{
    "name": "png-visual-compare",
    "version": "5.0.0",
    "description": "Node.js utility to compare PNG files or their areas",
    "keywords": [
        "visual testing",
        "compare png",
        "compare images",
        "png",
        "png compare",
        "png diff",
        "image diff",
        "diff"
    ],
    "homepage": "https://github.com/dichovsky/png-visual-compare#readme",
    "bugs": {
        "url": "https://github.com/dichovsky/png-visual-compare/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dichovsky/png-visual-compare.git"
    },
    "funding": {
        "type": "buymeacoffee",
        "url": "https://buymeacoffee.com/dichovsky"
    },
    "license": "MIT",
    "author": "Igor Magdich <magdich.igor@gmail.com>",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./out/index.d.ts",
            "default": "./out/index.js"
        }
    },
    "main": "./out/index.js",
    "types": "./out/index.d.ts",
    "files": [
        "./out"
    ],
    "scripts": {
        "prebuild": "npm run clean",
        "build": "tsc --pretty --project tsconfig.json",
        "clean": "rimraf ./out ./coverage ./test-results",
        "docker:build": "docker build --compress -t test-png-visual-compare .",
        "docker:run": "docker run --rm test-png-visual-compare",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "npm run test:unit",
        "test:all": "npm run test:unit && npm run test:e2e",
        "test:docker": "npm run clean && npm run docker:build && npm run docker:run",
        "pretest:e2e": "npx playwright install chromium",
        "test:e2e": "playwright test",
        "test:license": "npx --yes license-checker --production --onlyAllow \"ISC; MIT; MIT OR X11; BSD; Apache-2.0; Unlicense\"",
        "pretest:unit": "npm run clean && npm run lint && npm run format:check && npm run test:license && npm run build",
        "test:unit": "vitest run --coverage",
        "tool:excluded-areas-builder": "node -e \"const {execSync}=require('child_process');const cmd=process.platform==='win32'?'start':process.platform==='darwin'?'open':'xdg-open';execSync(cmd+' tools/excluded-areas-builder.html')\""
    },
    "dependencies": {
        "pixelmatch": "~7.1.0",
        "pngjs": "~7.0.0"
    },
    "devDependencies": {
        "@playwright/test": "~1.59.1",
        "@types/node": "~25.5.0",
        "@types/pngjs": "~6.0.5",
        "@vitest/coverage-v8": "~4.1.2",
        "eslint": "~10.1.0",
        "prettier": "~3.8.1",
        "rimraf": "~6.1.3",
        "typescript": "~6.0.2",
        "typescript-eslint": "~8.58.0",
        "vitest": "~4.1.2"
    },
    "engines": {
        "node": ">=20"
    }
}
